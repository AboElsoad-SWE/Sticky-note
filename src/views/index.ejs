<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sticky Notes</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>My Sticky Notes</h1>
            <a href="/add" class="btn">Add New Note</a>
        </header>

        <div class="notes-grid">
            <% if (notes.length > 0) { %>
                <% notes.forEach(note => { %>
                    <div class="note-card">
                        <h3><%= note.title %></h3>
                        <p><%= note.content %></p>
                        <small><%= new Date(note.createdAt).toLocaleDateString() %></small>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No notes found. Add some!</p>
            <% } %>
        </div>
    </div>
</body>
</html>
